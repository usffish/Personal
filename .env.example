# Copy this file to .env and fill in your keys.
# .env is gitignored and will never be committed.
#
# Load it before running the scraper:
#   source .env          (bash/zsh)
#   export $(cat .env | xargs)   (alternative)
#
# Or use a tool like direnv (https://direnv.net/) to load it automatically.

# Required — free key from https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_key_here

# Optional — enables Gemini slug disambiguation for hard-to-find titles
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Optional — enables ElevenLabs text-to-speech features
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here
